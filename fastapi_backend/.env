# fastapi_backend/.env
# --- Bảo mật JWT ---
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_EXPIRE_MINUTES=60

# --- Cơ sở dữ liệu ---
MYSQL_HOST=mysql
MYSQL_USER=iot
MYSQL_PASSWORD=iot123
MYSQL_DATABASE=iot_data
MONGO_URI=mongodb://mongodb:27017

# --- MQTT ---
MQTT_BROKER_HOST=mqtt
MQTT_PORT=1883
# Topic patterns – dùng {device_id} làm placeholder
MQTT_TOPIC_DATA=iot/devices/{device_id}/data
MQTT_TOPIC_STATUS=iot/devices/{device_id}/status
MQTT_TOPIC_CONTROL=iot/devices/{device_id}/control
MQTT_TOPIC_LWT=iot/devices/{device_id}/lwt

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Backend ---
# Đặt địa chỉ thực của server khi deploy (dùng trong HTTP ingest config)
BACKEND_HOST=http://localhost:8000

# --- Điều khiển relay qua HTTP tới edge (POST edge_control_url) ---
# Gửi X-API-Key = http_api_key của thiết bị trong MySQL (trùng file JSON config tải về)
EDGE_CONTROL_USE_DEVICE_HTTP_KEY=1
# Hoặc một key cố định: EDGE_CONTROL_API_KEY=ak_...

# --- CORS ---
# Thêm các origin cách nhau bởi dấu phẩy khi deploy production
ALLOWED_ORIGINS=*

# --- Commands ngoài danh sách mặc định (JSON format, tuỳ chọn) ---
# Ví dụ: DEVICE_EXTRA_COMMANDS={"my_custom_cmd": {"command": "xyz", "param": 1}}
# DEVICE_EXTRA_COMMANDS=